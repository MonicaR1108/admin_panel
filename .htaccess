Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to framework / sensitive directories if the project root is web-accessible.
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]
    RewriteRule ^\.env - [F,L]

    # Redirect everything to public/ (Laravel web root).
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

